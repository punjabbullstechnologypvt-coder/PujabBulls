{
  "routes": [
    {
      "src": "^/about\\.html$",
      "status": 301,
      "headers": { "Location": "/about" }
    },
    {
      "src": "^/distribution\\.html$",
      "status": 301,
      "headers": { "Location": "/industries" }
    },
    {
      "src": "^/privacy\\.html$",
      "status": 301,
      "headers": { "Location": "/privacy-policy" }
    },
    {
      "src": "^/terms\\.html$",
      "status": 301,
      "headers": { "Location": "/privacy-policy" }
    },
    {
      "src": "^/microsoft-dynamics-365-business-central\\.html$",
      "status": 301,
      "headers": { "Location": "/products" }
    },

    {
      "src": "^/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },

    {
      "src": "^/sitemap.xml$",
      "dest": "/sitemap.xml"
    },

    {
      "src": "^/robots.txt$",
      "dest": "/robots.txt"
    },

    {
      "src": "^(?!/assets/|/sitemap.xml|/robots.txt).*$",
      "dest": "/index.html"
    }
  ]
}